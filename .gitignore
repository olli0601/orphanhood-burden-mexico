# Raw inputs. Auto-downloadable sources (fetched by scripts-R/ch1_010) are NOT
# tracked. The request-gated MANUAL files that cannot be re-sourced — pre-2017
# registered births + ALL registered deaths — are intentionally left tracked so
# they are not lost.
#   WARNING: some are very large (>100 MB; e.g. the deaths bundles). Plain GitHub
#   rejects files >100 MB — use Git LFS or a non-GitHub remote before committing
#   these (see README). Nothing here is auto-committed.
input-data-raw/population/
input-data-raw/marginalization/
input-data-raw/geometries/
input-data-raw/births/natalidad_*/
input-data-raw/births/*201[789]*
input-data-raw/births/*202[0-4]*

# OS cruft
.DS_Store

# Generated outputs (plots, model objects, etc.)
output/

# R default graphics device dump (created at cwd by Rscript when a plot is
# print()ed without an explicit device; figures are saved explicitly via ggsave)
Rplots.pdf

# Python artifacts
__pycache__/
*.pyc
*.pt

# Pixi environment
.pixi/
pixi.lock

# Processed data: ignore ALL contents (regenerable by the pipeline, or supplied
# via the Dropbox mirror in README), but keep the directory itself in the repo
# via a tracked .gitkeep.
input-data-processed/*
!input-data-processed/.gitkeep
