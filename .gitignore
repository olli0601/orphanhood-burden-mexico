# Raw input data (large, downloaded via R/get_input_data_raw.R — not version controlled)
input-data-raw/

# OS cruft
.DS_Store

# Generated outputs (plots, model objects, etc.)
output/

# R default graphics device dump (created at cwd by Rscript when a plot is
# print()ed without an explicit device; figures are saved explicitly via ggsave)
Rplots.pdf

# Python artifacts
__pycache__/
*.pyc
*.pt

# Pixi environment
.pixi/
pixi.lock

# Processed datasets (per-year panels + derived intermediates) — large, not
# version controlled. Mirror copies via the Dropbox links in README (# Data).
input-data-processed/**/*.RDS
input-data-processed/*.RDS
input-data-processed/**/*.rds
input-data-processed/*.rds
